---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteWidget from '../../components/QuoteWidget.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../../site.config';
import { getAllDepartments, getCitiesByDepartment } from '../../lib/cities';

export function getStaticPaths() {
  return getAllDepartments().map(dept => ({
    params: { dept: dept.code.toLowerCase() },
    props: { dept },
  }));
}

const { dept } = Astro.props;
const cities = getCitiesByDepartment(dept.code);
const allDepartments = getAllDepartments();
const nearbyDepts = allDepartments.filter(d => d.region === dept.region && d.code !== dept.code).slice(0, 6);

// Zone climatique
const ZONE_MAP: Record<string,string> = {
  'Île-de-France':'H1a','Hauts-de-France':'H1a','Grand Est':'H1b','Bourgogne-Franche-Comté':'H1c',
  'Normandie':'H2a','Bretagne':'H2a','Pays de la Loire':'H2b','Centre-Val de Loire':'H2b',
  'Nouvelle-Aquitaine':'H2c','Auvergne-Rhône-Alpes':'H1c','Occitanie':'H3',
  "Provence-Alpes-Côte d'Azur":'H3','Corse':'H3'
};
const zone = ZONE_MAP[dept.region] || 'H2b';
const zg = zone.startsWith('H1') ? 'H1' : zone.startsWith('H3') ? 'H3' : 'H2';

const title = `Poêle à bois ${dept.name} (${dept.code}) — Prix & Installateurs RGE 2026`;
const description = `Comparez les prix d'installation de poêle à bois dans le ${dept.name} (${dept.code}). ${cities.length} villes couvertes. Devis gratuits d'artisans RGE QualiBois en ${dept.region}.`;

const jsonLd = [
  {"@context":"https://schema.org","@type":"CollectionPage",
    "name":`Poêle à bois - ${dept.name}`,"description":description,
    "url":`https://www.${siteConfig.domain}/departement/${dept.code.toLowerCase()}`},
  {"@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Accueil","item":`https://www.${siteConfig.domain}`},
      {"@type":"ListItem","position":2,"name":"Annuaire","item":`https://www.${siteConfig.domain}/annuaire`},
      {"@type":"ListItem","position":3,"name":dept.name}]}
];
---

<BaseLayout title={title} description={description} canonical={`/departement/${dept.code.toLowerCase()}`} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Annuaire", href: "/annuaire" },
        { label: dept.name, href: `/departement/${dept.code.toLowerCase()}` },
      ]} />

      <div class="grid lg:grid-cols-5 gap-10 items-start mt-6">
        <div class="lg:col-span-3">
          <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-3 py-1.5 rounded-full text-sm mb-4">
            <span>📍</span><span>{dept.region}</span>
          </div>

          <h1 class="text-2xl md:text-4xl font-extrabold leading-tight mb-4">
            Poêle à bois dans le {dept.name} ({dept.code})
          </h1>

          <p class="text-gray-300 leading-relaxed mb-6 max-w-xl">
            Trouvez un installateur certifié <strong class="text-white">RGE QualiBois</strong> pour votre poêle à bois dans le {dept.name}.
            <strong class="text-white">{cities.length} villes couvertes</strong>, devis gratuits et sans engagement.
          </p>

          <div class="flex flex-wrap gap-3 mb-6">
            <span class="bg-white/10 backdrop-blur-sm border border-white/20 px-3 py-1.5 rounded-full text-sm">✓ {cities.length} villes</span>
            <span class="bg-white/10 backdrop-blur-sm border border-white/20 px-3 py-1.5 rounded-full text-sm">✓ Zone climatique {zone}</span>
            <span class="bg-white/10 backdrop-blur-sm border border-white/20 px-3 py-1.5 rounded-full text-sm">✓ Artisans QualiBois</span>
          </div>

          <a href="/devis" class="inline-block bg-accent-500 hover:bg-accent-600 text-dark font-bold px-6 py-3.5 rounded-xl transition-colors shadow-lg text-base">
            🔥 Devis Gratuit dans le {dept.name}
          </a>
        </div>

        <div class="lg:col-span-2" id="devis-form">
          <div class="sticky top-20">
            <QuoteWidget keyword={`Poêle à bois ${dept.name}`} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-10">

    <!-- Local Info -->
    <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">
        🔥 Installer un poêle à bois dans le {dept.name}
      </h2>
      <div class="prose max-w-none text-gray-600 space-y-4">
        <p>
          Le département du <strong>{dept.name}</strong> ({dept.code}), situé en région <strong>{dept.region}</strong>,
          est classé en <strong>zone climatique {zone}</strong>.
          {zg === 'H1' ? " Les hivers rigoureux font du poêle à bois un chauffage principal idéal, avec des besoins thermiques élevés. Un poêle de masse ou en fonte à forte inertie est particulièrement recommandé pour restituer la chaleur sur de longues heures." :
           zg === 'H3' ? " Le climat doux et ensoleillé permet d'utiliser le poêle principalement comme chauffage d'appoint ou de confort. Un modèle de 6 à 8 kW suffit pour la plupart des logements, avec un usage concentré sur les mois d'hiver (novembre à mars)." :
           " Le climat tempéré fait du poêle à bois un excellent compromis entre chauffage d'appoint et chauffage principal. Les essences locales fournissent un combustible abordable et de qualité."}
        </p>
        <p>
          Nos <strong>{cities.length} villes couvertes</strong> dans le {dept.name} vous garantissent l'accès à des
          installateurs certifiés RGE QualiBois proches de chez vous. La proximité réduit les frais de
          déplacement et assure un SAV réactif, notamment pour le ramonage annuel obligatoire.
        </p>
      </div>
    </section>

    <!-- Price Range -->
    <section class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl border border-green-200 p-6 md:p-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        💰 Prix moyen d'un poêle à bois dans le {dept.name}
      </h2>
      <div class="grid sm:grid-cols-3 gap-4 mb-4">
        <div class="bg-white rounded-xl p-4 text-center border border-green-100">
          <span class="block text-sm text-gray-500 mb-1">Poêle acier standard</span>
          <span class="block text-xl font-bold text-gray-900">{zg === 'H1' ? '2 800€' : zg === 'H3' ? '2 400€' : '2 500€'}</span>
          <span class="block text-xs text-gray-400">6-8 kW posé</span>
        </div>
        <div class="bg-white rounded-xl p-4 text-center border border-brand-200 ring-2 ring-brand-100">
          <span class="block text-sm text-brand-600 font-medium mb-1">Le plus courant</span>
          <span class="block text-xl font-bold text-gray-900">{zg === 'H1' ? '4 500€' : zg === 'H3' ? '3 800€' : '4 000€'}</span>
          <span class="block text-xs text-gray-400">8-12 kW fonte posé</span>
        </div>
        <div class="bg-white rounded-xl p-4 text-center border border-green-100">
          <span class="block text-sm text-gray-500 mb-1">Poêle de masse</span>
          <span class="block text-xl font-bold text-gray-900">{zg === 'H1' ? '8 000€' : zg === 'H3' ? '6 500€' : '7 000€'}</span>
          <span class="block text-xs text-gray-400">Accumulation / pierre ollaire</span>
        </div>
      </div>
      <p class="text-sm text-gray-500">
        Prix TTC pose et tubage compris, avant déduction des aides. Après MaPrimeRénov' + CEE + TVA 5,5%, le reste à charge moyen dans le {dept.name} est de
        <strong>{zg === 'H1' ? '1 500 – 4 000€' : zg === 'H3' ? '1 000 – 3 000€' : '1 200 – 3 500€'}</strong>.
      </p>
    </section>

    <!-- Cities Grid -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">
        📍 Toutes les villes du {dept.name} ({dept.code})
      </h2>
      <p class="text-gray-500 text-sm mb-6">Cliquez sur une ville pour voir les prix et obtenir vos devis gratuits</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
        {cities.map((city) => (
          <a href={`/${city.slug}`}
            class="bg-white border border-gray-200 rounded-xl px-4 py-3 hover:border-brand-300 hover:shadow-md transition-all group text-center">
            <span class="font-semibold text-gray-900 group-hover:text-brand-600 text-sm block">{city.name}</span>
            <span class="text-xs text-gray-400">{city.zip}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Nearby Departments -->
    {nearbyDepts.length > 0 && (
      <section>
        <h2 class="text-xl font-bold text-gray-900 mb-4">🗺️ Départements voisins en {dept.region}</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {nearbyDepts.map((nd) => (
            <a href={`/departement/${nd.code.toLowerCase()}`}
              class="bg-white border border-gray-200 rounded-xl px-5 py-4 hover:border-brand-300 hover:shadow-md transition-all group">
              <span class="font-semibold text-gray-900 group-hover:text-brand-600 text-sm block">{nd.name} ({nd.code})</span>
              <span class="text-xs text-gray-400">{nd.count} {nd.count > 1 ? 'villes' : 'ville'} • {nd.region}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="pb-20 md:pb-0">
      <div class="bg-gradient-to-r from-brand-600 to-brand-800 rounded-2xl p-8 text-center text-white">
        <h2 class="text-xl md:text-2xl font-bold mb-3">
          Obtenez vos 3 devis Poêle à bois dans le {dept.name}
        </h2>
        <p class="text-brand-100 mb-5 text-sm">Gratuit • Sans engagement • Artisans RGE QualiBois du {dept.name}</p>
        <a href="/devis" class="inline-block bg-white text-brand-700 font-bold px-8 py-3.5 rounded-xl hover:bg-brand-50 transition-colors shadow-lg">
          Demander mes devis →
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
