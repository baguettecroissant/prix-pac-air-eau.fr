---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteWidget from '../components/QuoteWidget.astro';
import PriceTable from '../components/PriceTable.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FAQ from '../components/FAQ.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { siteConfig } from '../../site.config';
import { getAllCities, getNearbyCities, getCitiesByDepartment, getAllDepartments } from '../lib/cities';
import { blogArticles } from '../data/blog-articles';
import localContentRaw from '../data/local-content.json';

const localContent = localContentRaw as Record<string, {
  intro: string; local_tip: string; history_anecdote: string;
  faq_local: { q: string; a: string } | { question: string; answer: string };
  faq_local_2?: { q: string; a: string } | { question: string; answer: string };
  market_data: string;
  external_links?: { label: string; url: string; desc: string }[];
  local_pricing?: Record<string, { label: string; price: string }>;
  zone?: string; zone_group?: string;
  wood_species?: string; best_wood?: string;
  ramonage?: string; prix_stere?: string;
  n_installers?: number; n_cities_dept?: number;
  reste_a_charge?: number; total_aides?: number;
}>;

export function getStaticPaths() {
  return getAllCities().map(city => ({ params: { city: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const nearbyCities = getNearbyCities(city, 8);
const lc = localContent[city.slug];
const deptCities = getCitiesByDepartment(city.deptCode).slice(0, 12);

// SEO
const title = siteConfig.niche.seoTitleTemplate.replace('{city}', city.name).replace('{zip}', city.zip);
const description = siteConfig.niche.metaDescTemplate.replace('{city}', city.name).replace('{zip}', city.zip);

// Seed
const seed = city.slug.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0);

// Zone
const zone = lc?.zone || 'H2b';
const zg = lc?.zone_group || 'H2';

// FAQ
const faqNorm = (f: any) => ({ q: f.q || f.question, a: f.a || f.answer });
const faqItems = [
  ...siteConfig.faq.slice(0, 4),
  ...(lc ? [faqNorm(lc.faq_local)] : []),
  ...(lc?.faq_local_2 ? [faqNorm(lc.faq_local_2)] : []),
];

// Blog links (pick 3 deterministic)
const blogLinks = [...blogArticles].sort((a,b) => ((a.slug.length*seed)%7) - ((b.slug.length*seed)%7)).slice(0,3);

// Schema.org
const jsonLd = [
  { "@context":"https://schema.org","@type":"Service",
    "name":`${siteConfig.niche.name} à ${city.name}`,"description":description,
    "areaServed":{"@type":"City","name":city.name,"postalCode":city.zip},
    "provider":{"@type":"LocalBusiness","name":siteConfig.name,"url":`https://www.${siteConfig.domain}/${city.slug}`}},
  { "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Accueil","item":`https://www.${siteConfig.domain}`},
      {"@type":"ListItem","position":2,"name":"Annuaire","item":`https://www.${siteConfig.domain}/annuaire`},
      {"@type":"ListItem","position":3,"name":city.deptName,"item":`https://www.${siteConfig.domain}/departement/${city.deptCode.toLowerCase()}`},
      {"@type":"ListItem","position":4,"name":city.name}]},
  { "@context":"https://schema.org","@type":"FAQPage",
    "mainEntity":faqItems.map(f => ({"@type":"Question","name":f.q.replace('{city}',city.name),
      "acceptedAnswer":{"@type":"Answer","text":f.a.replace('{city}',city.name)}}))}
];

// Benefits (poêle specific)
const benefits = [
  `Énergie la **moins chère** de France : ~0,04€/kWh bois`,
  `Artisans **certifiés RGE QualiBois** dans le ${city.deptName}`,
  `Éligible **MaPrimeRénov' 2026** + Prime CEE cumulables`,
  `Rendement **>80%** avec le label Flamme Verte 7★`,
  `Bilan carbone **quasi neutre** (bois = énergie renouvelable)`,
  `Durée de vie **20 à 25 ans** pour un poêle en fonte`,
].sort((a, b) => {
  const ha = a.charCodeAt(seed % a.length);
  const hb = b.charCodeAt(seed % b.length);
  return ha - hb;
});
---

<BaseLayout title={title} description={description} canonical={`/${city.slug}`} jsonLd={jsonLd}>

  <!-- Hero -->
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Annuaire", href: "/annuaire" },
        { label: city.deptName, href: `/departement/${city.deptCode.toLowerCase()}` },
        { label: city.name, href: `/${city.slug}` },
      ]} />

      <div class="grid lg:grid-cols-5 gap-10 items-start mt-6">
        <div class="lg:col-span-3">
          <h1 class="text-2xl md:text-4xl font-extrabold leading-tight mb-6">
            {siteConfig.niche.name} à {city.name} ({city.zip})<br/>
            <span class="text-brand-200 text-xl md:text-2xl font-bold">Prix & Devis Gratuit 2026</span>
          </h1>

          <div class="mb-8">
            <p class="text-gray-300 leading-relaxed" set:html={
              (lc?.intro || `Comparez les prix d'installation de **poêle à bois** à **${city.name}** (${city.zip}). Recevez jusqu'à 3 devis gratuits d'artisans certifiés RGE QualiBois dans le ${city.deptName}.`)
              .replace(/\*\*(.*?)\*\*/g, '<strong class="text-white">$1</strong>')
            } />
          </div>

          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {benefits.map((b) => (
              <div class="flex items-start gap-2 bg-white/5 backdrop-blur-sm rounded-lg px-4 py-3 border border-white/10">
                <span class="text-green-400 mt-0.5">✓</span>
                <span class="text-sm text-gray-200" set:html={b.replace(/\*\*(.*?)\*\*/g, '<strong class="text-white">$1</strong>')} />
              </div>
            ))}
          </div>

          <a href="/devis" class="inline-block bg-accent-500 hover:bg-accent-600 text-dark font-bold px-6 py-3.5 rounded-xl transition-colors shadow-lg text-base">
            🔥 Comparer 3 Devis à {city.name}
          </a>
        </div>

        <div class="lg:col-span-2" id="devis-form">
          <div class="sticky top-20">
            <QuoteWidget keyword={`${siteConfig.niche.name} ${city.name}`} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-10">

    {/* Section: Local Expert Content */}
    {lc && (
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">
          🔥 Installer un poêle à bois à {city.name} ({city.deptCode})
        </h2>
        <div class="prose max-w-none text-gray-600 space-y-4">
          <p>{lc.intro}</p>

          <div class="bg-amber-50 border-l-4 border-amber-500 p-4 rounded-r-lg my-6">
            <h3 class="text-amber-900 font-bold text-base mb-2">💡 Conseil expert — {city.name}</h3>
            <p class="text-amber-800 text-sm">{lc.local_tip}</p>
          </div>

          <p class="italic text-gray-500 border-l-2 border-gray-200 pl-4">
            📜 {lc.history_anecdote}
          </p>
        </div>
      </section>
    )}

    {/* Section: Local Pricing */}
    {lc?.local_pricing && (
      <section class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl border border-green-200 p-6 md:p-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">
          💰 Tarifs poêle à bois — {city.name} ({city.deptName})
        </h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-white/60 text-gray-500 border-b border-green-200">
                <th class="px-4 py-3 text-left font-semibold">Prestation</th>
                <th class="px-4 py-3 text-left font-semibold">Prix TTC posé ({city.deptCode})</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-green-100">
              {Object.values(lc.local_pricing).map((row) => (
                <tr>
                  <td class="px-4 py-3 font-medium text-gray-900">{row.label}</td>
                  <td class="px-4 py-3 text-gray-700">{row.price}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-500 mt-3">
          Prix TTC moyens constatés dans le {city.deptName} en 2026, pose comprise. Avant déduction des aides.
          {lc.total_aides && <span> Aides cumulables : jusqu'à <strong>{lc.total_aides}€</strong> (MaPrimeRénov' + CEE).</span>}
        </p>
      </section>
    )}

    {/* Section: Market Data */}
    {lc?.market_data && (
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
        <h2 class="text-xl font-bold text-gray-900 mb-3">
          📊 Baromètre du marché — {city.deptName} ({city.deptCode})
        </h2>
        <p class="text-gray-700 leading-relaxed">{lc.market_data}</p>

        {lc.wood_species && (
          <div class="mt-4 bg-gray-50 rounded-xl p-4 border border-gray-100">
            <h3 class="text-sm font-bold text-gray-900 mb-2">🌳 Essences de bois recommandées en {city.region}</h3>
            <p class="text-sm text-gray-600">
              <strong>{lc.wood_species}</strong>. Le <strong>{lc.best_wood}</strong> est l'essence la plus
              prisée pour son haut pouvoir calorifique (~2 100 kWh/stère) et sa combustion lente.
              Prix du stère sec en {city.region} : <strong>{lc.prix_stere}</strong>.
            </p>
          </div>
        )}
      </section>
    )}

    {/* Section: Technical Guide */}
    <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">
        ⚙️ Guide technique : choisir son poêle à bois à {city.name}
      </h2>
      <div class="prose max-w-none text-gray-600 space-y-6">
        <div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Quelle puissance pour votre logement ?</h3>
          <p>
            Le dimensionnement est la clé d'une installation réussie. En zone <strong>{zone}</strong> ({city.region}),
            la règle de base est <strong>1 kW pour {zg === 'H1' ? '8 à 10' : zg === 'H3' ? '12 à 15' : '10 à 12'} m²</strong>
            pour une maison correctement isolée (DPE C ou mieux).
          </p>
          <ul class="space-y-2 mt-3">
            <li class="flex items-start gap-2">
              <span class="text-brand-600 font-bold">→</span>
              <span><strong>Maison 80 m²</strong> : poêle de {zg === 'H1' ? '8 à 10' : zg === 'H3' ? '5 à 7' : '7 à 8'} kW</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 font-bold">→</span>
              <span><strong>Maison 120 m²</strong> : poêle de {zg === 'H1' ? '12 à 15' : zg === 'H3' ? '8 à 10' : '10 à 12'} kW</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-brand-600 font-bold">→</span>
              <span><strong>Chauffage d'appoint (salon)</strong> : poêle de 6 à 8 kW quel que soit le logement</span>
            </li>
          </ul>
          <p class="mt-3 text-sm text-amber-700 bg-amber-50 rounded-lg p-3 border border-amber-200">
            ⚠️ <strong>Attention au surdimensionnement</strong> : un poêle trop puissant tournera au ralenti,
            encrassera le conduit (bistre) et noircira la vitre en 24h. C'est l'erreur n°1 à {city.name}.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Poêle à bûches vs Poêle à granulés à {city.name}</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-gray-50 text-gray-500 border-b border-gray-200">
                  <th class="px-4 py-3 text-left font-semibold">Critère</th>
                  <th class="px-4 py-3 text-left font-semibold">🪵 Poêle à bûches</th>
                  <th class="px-4 py-3 text-left font-semibold">🫘 Poêle à granulés</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr><td class="px-4 py-3 font-medium">Coût du combustible</td><td class="px-4 py-3 text-green-700">~0,04€/kWh</td><td class="px-4 py-3">~0,065€/kWh</td></tr>
                <tr><td class="px-4 py-3 font-medium">Autonomie</td><td class="px-4 py-3">4 à 10h (rechargement manuel)</td><td class="px-4 py-3 text-green-700">12 à 48h (réservoir)</td></tr>
                <tr><td class="px-4 py-3 font-medium">Programmation</td><td class="px-4 py-3">Non</td><td class="px-4 py-3 text-green-700">Oui (thermostat, horaires)</td></tr>
                <tr><td class="px-4 py-3 font-medium">Qualité de flamme</td><td class="px-4 py-3 text-green-700">⭐⭐⭐⭐⭐ (authentique)</td><td class="px-4 py-3">⭐⭐⭐</td></tr>
                <tr><td class="px-4 py-3 font-medium">Électricité requise</td><td class="px-4 py-3 text-green-700">Non (autonome)</td><td class="px-4 py-3">Oui (ventilateur, vis)</td></tr>
                <tr><td class="px-4 py-3 font-medium">Budget posé ({city.deptCode})</td><td class="px-4 py-3">{zg === 'H1' ? '2 500 – 6 000€' : '2 200 – 5 500€'}</td><td class="px-4 py-3">{zg === 'H1' ? '3 500 – 7 500€' : '3 000 – 7 000€'}</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Déroulement de l'installation à {city.name}</h3>
          <ol class="space-y-3 mt-3 list-decimal list-inside">
            <li><strong>Visite technique gratuite</strong> — L'installateur RGE QualiBois vérifie le conduit existant (ou étudie la création), mesure les volumes et évalue l'isolation. Durée : 1h.</li>
            <li><strong>Devis détaillé</strong> — Vous recevez un devis conforme précisant : marque/modèle, puissance (kW), rendement (%), détail fumisterie, et montant des aides déductibles.</li>
            <li><strong>Dépôt des dossiers d'aides</strong> — Le devis est signé APRÈS validation de votre demande MaPrimeRénov' sur le site de l'ANAH. L'artisan vous aide pour les formalités CEE.</li>
            <li><strong>Installation</strong> — Pose du poêle, raccordement au conduit (tubage inox si nécessaire), plaque de sol si le sol est combustible, arrivée d'air frais. Durée : 1 journée.</li>
            <li><strong>Mise en service & premier allumage</strong> — Le technicien vérifie le tirage, effectue un test de combustion et vous explique les bonnes pratiques (allumage inversé, bois sec).</li>
          </ol>
        </div>

        {lc?.ramonage && (
          <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg">
            <h3 class="text-red-900 font-bold text-base mb-2">🧹 Obligation de ramonage — {city.deptName} ({city.deptCode})</h3>
            <p class="text-red-800 text-sm">
              Dans le {city.deptName} : <strong>{lc.ramonage}</strong>.
              Le certificat de ramonage délivré par un professionnel est obligatoire pour votre assurance habitation.
              Coût moyen : 60€ à 120€ par intervention.
            </p>
          </div>
        )}
      </div>
    </section>

    {/* Section: External Authority Links */}
    {lc?.external_links && lc.external_links.length > 0 && (
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">
          🔗 Ressources officielles — {city.name}
        </h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {lc.external_links.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer"
              class="flex items-start gap-3 bg-gray-50 rounded-xl p-4 border border-gray-100 hover:border-brand-300 hover:shadow-md transition-all group">
              <span class="text-brand-600 mt-0.5">↗</span>
              <div>
                <span class="font-semibold text-gray-900 group-hover:text-brand-600 text-sm block">{link.label}</span>
                <span class="text-xs text-gray-400">{link.desc}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Section: Price Table (global) */}
    <section>
      <p class="text-sm text-gray-500 mb-4">
        💡 Les prix ci-dessous sont des moyennes nationales. À {city.name} (zone {zone}, {city.region}),
        les tarifs peuvent varier de ±{zg === 'H1' ? '15' : '10'}% selon
        l'accessibilité du chantier, la configuration du conduit et la gamme choisie.
      </p>
      <PriceTable />
    </section>

    {/* Section: Process Steps */}
    <ProcessSteps />

    {/* Section: FAQ */}
    <FAQ items={faqItems} cityName={city.name} />

    {/* Section: Blog Links */}
    <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        📚 Guides pour votre projet poêle à bois
      </h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {blogLinks.map((article) => (
          <a href={`/blog/${article.slug}`} class="group">
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 hover:border-brand-300 hover:shadow-md transition-all h-full">
              <span class="text-2xl mb-2 block">{article.emoji}</span>
              <span class="font-semibold text-gray-900 group-hover:text-brand-600 text-sm block leading-snug">{article.title}</span>
              <span class="text-xs text-gray-400 mt-2 block">{article.readTime} de lecture</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    {/* Section: Nearby Cities */}
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">
        📍 Poêle à bois près de {city.name}
      </h2>
      <p class="text-gray-500 text-sm mb-6">Nos installateurs RGE interviennent aussi dans ces communes du {city.deptName}</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {nearbyCities.map((nc) => (
          <a href={`/${nc.slug}`}
            class="bg-white border border-gray-200 rounded-xl px-4 py-3 hover:border-brand-300 hover:shadow-md transition-all group text-center">
            <span class="font-semibold text-gray-900 group-hover:text-brand-600 text-sm block">{nc.name}</span>
            <span class="text-xs text-gray-400">{nc.zip} • {nc.deptName}</span>
          </a>
        ))}
      </div>
    </section>

    {/* Department link */}
    <section>
      <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 text-center">
        <p class="text-sm text-gray-600">
          Voir toutes les villes du
          <a href={`/departement/${city.deptCode.toLowerCase()}`} class="text-brand-600 font-semibold hover:underline">
            {city.deptName} ({city.deptCode})
          </a>
          — {deptCities.length > 12 ? '12+' : deptCities.length} communes couvertes
        </p>
      </div>
    </section>

    {/* Final CTA */}
    <section class="pb-20 md:pb-0">
      <div class="bg-gradient-to-r from-brand-600 to-brand-800 rounded-2xl p-8 text-center text-white">
        <h2 class="text-xl md:text-2xl font-bold mb-3">
          Obtenez vos 3 devis Poêle à bois à {city.name}
        </h2>
        <p class="text-brand-100 mb-5 text-sm">
          Gratuit • Sans engagement • Artisans RGE QualiBois du {city.deptName}
        </p>
        <a href="/devis" class="inline-block bg-white text-brand-700 font-bold px-8 py-3.5 rounded-xl hover:bg-brand-50 transition-colors shadow-lg">
          Demander mes devis →
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
